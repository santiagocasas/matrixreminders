{
  "name": "matrix-reminder-bot",
  "version": "1.0.0",
  "description": "Matrix bot for natural language reminders and Google Calendar integration",
  "type": "commonjs",
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "auth:google": "node scripts/google_oauth_init.js",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "chrono-node": "^2.7.5",
    "googleapis": "^128.0.0",
    "js-yaml": "^4.1.0",
    "matrix-bot-sdk": "0.7.0",
    "pino": "^8.15.0",
    "pino-pretty": "^10.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
